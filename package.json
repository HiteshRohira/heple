{
  "name": "heple",
  "version": "0.0.4",
  "description": "Make HTML plans with good design. Always.",
  "keywords": [
    "cli",
    "html",
    "planning",
    "json",
    "documentation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HiteshRohira/heple.git"
  },
  "homepage": "https://github.com/HiteshRohira/heple#readme",
  "bugs": "https://github.com/HiteshRohira/heple/issues",
  "type": "module",
  "bin": {
    "heple": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "example.json"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm clean && tsc -p tsconfig.json",
    "prepack": "pnpm build",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:visual": "tsx tests/render.visual.ts",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.38",
    "ajv": "^8.17.1",
    "commander": "^14.0.0",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "html-validate": "11.5.6",
    "playwright-core": "1.61.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.0.0"
  },
  "packageManager": "pnpm@10.12.1"
}
